        "#Data visualization\n",
        "fig, axes = plt.subplots(nrows=2, ncols=5,figsize=(15, 5))\n",
        "ax = axes.ravel()\n",
        "for i in range(10):\n",
        "    ax[i].imshow(X_train[i].reshape(28, 28))\n",
        "    ax[i].title.set_text('Class:'+str(y_train[i]))\n",
        "plt.subplots_adjust(hspace=0.5)\n",
        "plt.show()"
